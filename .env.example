# Copy to .env.local for local dev. .env.local is gitignored.
# All values here are validated at startup via lib/env.ts (zod).

NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Intake form (lib/actions/intake.ts) ---
# Without RESEND_API_KEY the form still "works": submissions are logged
# to the dev server console. Set the key to actually send mail.
#
# 1. Sign up at https://resend.com (free 100 mails/day, no card)
# 2. Create API key, paste below.
# 3. From-address `onboarding@resend.dev` works without domain verification
#    — useful until oktobus.com DNS is set up. Then verify the domain in
#    Resend and update the `from` field in lib/actions/intake.ts.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CONTACT_TO_EMAIL=davidemeer@gmail.com
