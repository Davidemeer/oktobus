# Copy to .env.local (dev) or .env.production (prod). Both are gitignored.
# All values are validated at startup via lib/env.ts (zod).

# --- Runtime ---
NODE_ENV=development
# Set to production hostname when deployed:
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Intake form (lib/actions/intake.ts) ---
# Without RESEND_API_KEY the form "works" but only logs to the server
# console. Set the key in production to actually send mail.
#
#  1. Sign up at https://resend.com (free 100 mails/day, no card)
#  2. Verify oktobus.nl as a sending domain (DNS TXT/MX records).
#  3. Create an API key, paste it below.
#
# Default from-address: "Oktobus <intake@oktobus.nl>" (requires domain
# verification in Resend). While DNS isn't set up yet, override with:
#   RESEND_FROM="Oktobus Intake <onboarding@resend.dev>"
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=Oktobus <intake@oktobus.nl>

# Where intake submissions are forwarded. Defaults to davidemeer@gmail.com
# (see lib/env.ts) — override here if needed.
# CONTACT_TO_EMAIL=team@oktobus.nl
